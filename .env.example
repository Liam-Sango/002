# Live market ticker (HUD) — free Finnhub API key.
# Get one at https://finnhub.io/ (free tier).
#
# NOTE: this is a NEXT_PUBLIC_ var, so it is inlined into the static client
# bundle and is publicly visible. Only use a free, rate-limited key here.
# Without it, the ticker falls back to flavor readouts.
#
# Local dev: copy this file to `.env.local` and fill in the value.
# Production (GitHub Pages): set a repo secret named FINNHUB_KEY — the
# deploy workflow forwards it into this var at build time.
NEXT_PUBLIC_FINNHUB_KEY=
